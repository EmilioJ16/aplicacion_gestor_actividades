<?xml version="1.0" encoding="ISO-8859-1"?>

<!DOCTYPE web-app PUBLIC
"-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
"http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
    <display-name>Sporting activities searching</display-name>

    <servlet>
        <servlet-name>list</servlet-name>
        <servlet-class>list</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>list</servlet-name>
        <url-pattern>/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ConfirmRegisterServlet</servlet-name>
        <servlet-class>ConfirmRegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ConfirmRegisterServlet</servlet-name>
        <url-pattern>/confirmRegister</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
    
    <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>LoginServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AccessServlet</servlet-name>
    <servlet-class>AccessServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AccessServlet</servlet-name>
    <url-pattern>/access</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ManagerListServlet</servlet-name>
    <servlet-class>ManagerListServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ManagerListServlet</servlet-name>
    <url-pattern>/managerList</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ManagerLoginServlet</servlet-name>
    <servlet-class>ManagerLoginServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ManagerLoginServlet</servlet-name>
    <url-pattern>/managerLogin</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AddActivityServlet</servlet-name>
    <servlet-class>AddActivityServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddActivityServlet</servlet-name>
    <url-pattern>/addActivity</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>EditActivityServlet</servlet-name>
    <servlet-class>EditActivityServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>EditActivityServlet</servlet-name>
    <url-pattern>/editActivity</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>CancelRegisterServlet</servlet-name>
    <servlet-class>CancelRegisterServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>CancelRegisterServlet</servlet-name>
    <url-pattern>/cancelRegister</url-pattern>
</servlet-mapping>

</web-app>